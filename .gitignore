# Local .terraform directories
**/.terraform/*

# Terraform lock file (optional: some teams commit this)
# .terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Backend configuration (may contain sensitive info)
backend.tf.local